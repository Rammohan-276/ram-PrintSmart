# Marine Data Mapping Configuration

# Mapbox API Key (Get yours at https://mapbox.com)
# Required for Mapbox and deck.gl integration
REACT_APP_MAPBOX_TOKEN=pk.your-mapbox-token-here

# Marine Data Refresh Interval (in milliseconds)
# Default: 300000 (5 minutes)
REACT_APP_DATA_REFRESH_INTERVAL=300000

# Map Default Settings
REACT_APP_DEFAULT_MAP_CENTER_LAT=37.7749
REACT_APP_DEFAULT_MAP_CENTER_LNG=-122.4194
REACT_APP_DEFAULT_MAP_ZOOM=10

# API Endpoints (if using external marine data APIs)
# REACT_APP_MARINE_DATA_API_URL=https://your-marine-api.com
# REACT_APP_WEATHER_API_KEY=your-weather-api-key
# REACT_APP_OCEAN_DATA_API_KEY=your-ocean-data-key

# Performance Settings
REACT_APP_ENABLE_GPU_ACCELERATION=true
REACT_APP_MAP_RENDER_OPTIMIZATION=true
REACT_APP_MAX_DATA_POINTS=10000

# Debug Settings
REACT_APP_DEBUG_MAPS=false
REACT_APP_SHOW_PERFORMANCE_STATS=false